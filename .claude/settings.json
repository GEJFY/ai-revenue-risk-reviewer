{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(python3 -c:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(pytest:*)",
      "Read(./docs/**)",
      "Read(./config/**)",
      "Read(./.claude/**)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(pip install:*)",
      "Bash(python3 ./run:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./data/**)",
      "Read(./samples/real/**)"
    ]
  }
}
